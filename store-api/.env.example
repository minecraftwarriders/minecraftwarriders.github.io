PORT=8787
PUBLIC_SITE_URL=https://minecraftwarriders.github.io
CORS_ORIGIN=https://minecraftwarriders.github.io

# Stripe dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_live_replace_me

# Stripe dashboard/CLI webhook signing secret for /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional: Stripe Product Catalog price IDs. Use price_... IDs, not prod_... IDs or buy.stripe.com links.
# If blank, the API creates Checkout Sessions with the amounts in src/catalog.js.
STRIPE_PRICE_TRAIL_PERSONAL_SUNSHINE=
STRIPE_PRICE_TRAIL_COFFEE_WISPS=
STRIPE_PRICE_TRAIL_BUBBLE_WORLD=
STRIPE_PRICE_TRAIL_SOUL_FLAME=
STRIPE_PRICE_TRAIL_ENCHANTED_GLYPHS=
STRIPE_PRICE_PET_GERALD=
STRIPE_PRICE_PET_BUSINESS_CAT=
STRIPE_PRICE_PET_SAD_CRAB=
STRIPE_PRICE_PET_BISCUIT=
STRIPE_PRICE_PET_MOCHI=
STRIPE_PRICE_HAT_SUNNY_SIDE_UP=
STRIPE_PRICE_HAT_FEDORA=
STRIPE_PRICE_TAG_CERTIFIED_MENACE=
STRIPE_PRICE_TAG_DOING_MY_BEST=
STRIPE_PRICE_COIN_POCKET_CHANGE=
STRIPE_PRICE_COIN_LITTLE_TREAT=
STRIPE_PRICE_COIN_THE_SPLURGE=
STRIPE_PRICE_COIN_BIG_BAG=
STRIPE_PRICE_COIN_LOADED=
STRIPE_PRICE_COIN_UNHINGED=

